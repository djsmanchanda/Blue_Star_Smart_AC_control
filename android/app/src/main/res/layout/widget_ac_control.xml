<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:padding="2dp">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <TextView
            android:id="@+id/widget_main_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="27"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_zone_up"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_gravity="top"
            android:background="@drawable/widget_button"
            android:gravity="center"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="1sp" />

        <TextView
            android:id="@+id/widget_center_tap"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:background="@drawable/widget_button"
            android:gravity="center"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="1sp" />

        <TextView
            android:id="@+id/widget_zone_down"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_gravity="bottom"
            android:background="@drawable/widget_button"
            android:gravity="center"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="1sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/widget_display_state"
        android:layout_width="44dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="4dp"
        android:background="@drawable/widget_toggle_off"
        android:gravity="center"
        android:text="On"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
